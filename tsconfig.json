{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@db/*": ["./src/database/*"],
      "@db": ["./src/database/index.js"],
      "@modules/*": ["./src/modules/*"],
      "@lib/*": ["./src/lib/*"]
    }
  },
  "include": ["."]
}
